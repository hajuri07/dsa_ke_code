#include <iostream>
using namespace std;

int main() {
    int array[10] = {1, 2, 3, 67, 5};
    int n = 5;
    int item = 67;
    bool found = false;

    for(int i = 0; i < n; i++) {
        if(array[i] == item) {
            cout << "Enemy spotted at index " << i;
            found = true;
            break;  // stop after finding
        }
    }

    if(!found) {
        cout << "Nah nigga not found";
    }

    return 0;
}   
